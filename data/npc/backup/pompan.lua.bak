-- Pompan - Converted from XML to Lua NpcType
-- Original XML: data/npc/Pompan.xml
-- Original Script: data/npc/scripts/Pompan.lua

local npcName = "Pompan"
local npcType = Game.createNpcType(npcName)

-- NPC Properties (from XML)
npcType:name(npcName)
npcType:nameDescription("a pompan")
npcType:health(100)
npcType:maxHealth(100)
npcType:walkInterval(2000)
npcType:walkRadius(2)
npcType:baseSpeed(100)
npcType:floorChange(false)
npcType:isPushable(false)
npcType:outfit({lookType = 132, lookHead = 78, lookBody = 13, lookLegs = 32, lookFeet = 108})
npcType:speechBubble(SPEECHBUBBLE_TRADE)

