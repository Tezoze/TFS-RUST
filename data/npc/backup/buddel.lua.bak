-- Buddel - Converted from XML to Lua NpcType
-- Original XML: data/npc/Buddel.xml
-- Original Script: data/npc/scripts/Buddel.lua

local npcName = "Buddel"
local npcType = Game.createNpcType(npcName)

-- NPC Properties (from XML)
npcType:name(npcName)
npcType:nameDescription("a buddel")
npcType:health(100)
npcType:maxHealth(100)
npcType:walkInterval(2000)
npcType:walkRadius(2)
npcType:baseSpeed(100)
npcType:floorChange(false)
npcType:isPushable(false)
npcType:outfit({lookType = 143, lookHead = 19, lookBody = 57, lookLegs = 22, lookFeet = 20})
npcType:speechBubble(SPEECHBUBBLE_NORMAL)

-- Original Lua script content
local keywordHandler = KeywordHandler:new()
local npcHandler = NpcHandler:new(keywordHandler)


-- Travel
local function addTravelKeyword(keyword, cost, destination, text, condition)
	local blockText = 'No, no, no, you even are no barb....barba...er.. one of us!!!! Talk to the Jarl first! '

	-- Special handling for Tyrsung
	if keyword == 'tyrsung' then
		blockText = 'No, no, no, you even are no barb....barba...er.. one of us!!!! Talk to the Jarl first! Or maybe you should check with the shamans about helping them first... *HICKS*'
	end

	-- Special handling for all travel keywords
	local travelKeyword = keywordHandler:addKeyword({keyword}, function(cid, type, msg, matches, node)
		local player = Player(cid)
		if not player then
			npcHandler:say("Something went wrong. Please try again.", cid)
			return true
		end

		if condition and condition(player) then
			npcHandler:say(blockText, cid)
			return true
		else
			npcHandler:say(text or 'Give me |TRAVELCOST| and I bring you to ' .. keyword:titleCase() .. '. Alright?', cid)
			npcHandler.topic[cid] = 1 -- Set topic to allow child keywords
			return true
		end
	end, {npcHandler = npcHandler})

	-- Child keywords for travel
	travelKeyword:addChildKeyword({'yes'}, StdModule.travel, {npcHandler = npcHandler, premium = false, cost = cost, discount = 'postman', destination = destination})
	travelKeyword:addChildKeyword({'no'}, StdModule.say, {npcHandler = npcHandler, text = 'You shouldn\'t miss the experience.', reset = true})
end

keywordHandler:addKeyword({'svargrond'}, StdModule.say, {npcHandler = npcHandler, text = 'You know a town nicer than this? NICER DICER! Apropos, don\'t play dice when you are drunk ...'})
addTravelKeyword('okolnir', 50, Position(32225, 31381, 7), 'It\'s nice there. Except of the ice dragons which are not very companionable.', function(player) return player:getStorageValue(Storage.BarbarianTest.Questline) < 8 end)
addTravelKeyword('helheim', 50, Position(32462, 31174, 7), 'T\'at is a small island to the east.', function(player) return player:getStorageValue(Storage.BarbarianTest.Questline) < 8 end)
addTravelKeyword('tyrsung', 50, Position(32333, 31227, 7), '*HICKS* Big, big island east of here. Venorian hunters settled there ..... I could bring you north of their camp.', function(player) return player:getStorageValue(Storage.BarbarianTest.Questline) < 8 or player:getStorageValue(Storage.TheIceIslands.Questline) < 6 end)
addTravelKeyword('camp', 50, Position(32021, 31294, 7), 'Both of you look like you could defend yourself! If you want to go there, ask me for a passage.', function(player) return player:getStorageValue(Storage.BarbarianTest.Questline) < 8 end)

