	npcHandler = npcHandler,
	onlyFocus = true,
	text = 'Do you want to buy the fourth blessing for 10000 gold?'
})
node4:addChildKeyword({'yes'}, StdModule.bless, {
	npcHandler = npcHandler,
	bless = 4,
	premium = false,
