-- Runtel Blackspark - Converted from XML to Lua NpcType
-- Original XML: data/npc/Runtel Blackspark.xml
-- Original Script: data/npc/scripts/Runtel Blackspark.lua

local npcName = "Runtel Blackspark"
local npcType = Game.createNpcType(npcName)

-- NPC Properties (from XML)
npcType:name(npcName)
npcType:nameDescription("a runtel blackspark")
npcType:health(100)
npcType:maxHealth(100)
npcType:walkInterval(2000)
npcType:walkRadius(2)
npcType:baseSpeed(100)
npcType:floorChange(false)
npcType:isPushable(false)
npcType:outfit({lookType = 472, lookHead = 59, lookBody = 114, lookFeet = 94, lookAddons = 1})
npcType:speechBubble(SPEECHBUBBLE_NORMAL)

-- Original Lua script content
local keywordHandler = KeywordHandler:new()
local npcHandler = NpcHandler:new(keywordHandler)


-- Shop items (from XML parameters)
local shopItems = {
    {id = 7591, buy = 190, sell = 0, subType = 0, name = "great health potion"},
    {id = 7590, buy = 120, sell = 0, subType = 0, name = "great mana potion"},
