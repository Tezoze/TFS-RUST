-- Black Bert - Converted from XML to Lua NpcType
-- Original XML: data/npc/Black Bert.xml
-- Original Script: data/npc/scripts/Black Bert.lua

local npcName = "Black Bert"
local npcType = Game.createNpcType(npcName)

-- NPC Properties (from XML)
npcType:name(npcName)
npcType:nameDescription("a black bert")
npcType:health(100)
npcType:maxHealth(100)
npcType:walkInterval(2000)
npcType:walkRadius(2)
npcType:baseSpeed(100)
npcType:floorChange(false)
npcType:isPushable(false)
npcType:outfit({lookType = 151, lookBody = 38, lookLegs = 19, lookFeet = 76})
npcType:speechBubble(SPEECHBUBBLE_TRADE)

-- Original Lua script content
local keywordHandler = KeywordHandler:new()
local npcHandler = NpcHandler:new(keywordHandler)

local shopModule = ShopModule:new()
npcHandler:addModule(shopModule)

-- CONFIGURATION
local STORAGE_THIEVES_GUILD = Storage.thievesGuild.Quest
local REQUIRED_STORAGE_VALUE = 9


-- 1. VOICE MODULE
local voices = {
    { text = 'Psst! Over here!' }
}
npcHandler:addModule(VoiceModule:new(voices))

-- 2. GREETING CONDITION
local function greetCallback(cid)
    local player = Player(cid)
    
    if player:getStorageValue(STORAGE_THIEVES_GUILD) < REQUIRED_STORAGE_VALUE then
        npcHandler:say("I'm busy. Go talk to Dorian if you want something.", cid)
        return false -- Prevents the NPC from focusing on the player
    end

    npcHandler:setMessage(MESSAGE_GREET, "Psst! Over here! You're the one Dorian mentioned, right? Want to see my {wares}?")
    return true
end

-- 3. TRADE BLOCKER
local function onTradeRequest(cid)
    local player = Player(cid)
    if player:getStorageValue(STORAGE_THIEVES_GUILD) < REQUIRED_STORAGE_VALUE then
        npcHandler:say("I only trade with those who have earned the trust of our guild.", cid)
        return false
    end
    return true
end

